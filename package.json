{
  "name": "tavoli",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build && electron .",
    "dist": "npm run dist:linux && npm run dist:win",
    "dist:linux": "npm run build && electron-builder --linux --config.directories.output=dist-electron/linux",
    "dist:win": "electron-builder --win --config.directories.output=dist-electron/windows",
    "publish:linux": "npm run build && electron-builder --linux --publish always --config.directories.output=dist-electron/linux",
    "publish:win": "electron-builder --win --publish always --config.directories.output=dist-electron/windows",
    "publish": ". ./.env && npm run publish:linux && npm run publish:win"
  },
  "build": {
    "appId": "it.tavoli.piantina",
    "productName": "Tavoli",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "francesco-lapenna",
        "repo": "Tavoli",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "jspdf": "^4.2.1",
    "konva": "^10.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "electron-winstaller@5.4.0": true
  }
}
